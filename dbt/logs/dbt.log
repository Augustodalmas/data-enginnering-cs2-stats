    create temporary table
      "posicionamento_jogador_partida__dbt_tmp20260628152510264309"
  
    as (
      

SELECT
    t.match_id,
    t.steamid,
    ANY_VALUE(t.name)          AS nome,
    t.place,
    COUNT(*)                   AS qtd_ticks,
